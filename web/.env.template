# ──────────────────────────────────────────────
# Kontak Web (Next.js) — Environment Variables
# Copy this file to .env.local and fill in values
# ──────────────────────────────────────────────

# ── App ───────────────────────────────────────
NODE_ENV=development

# ── Backend API ───────────────────────────────
BACKEND_URL=http://localhost:8080
KONTAK_API_URL=http://localhost:8080

# ── Public (exposed to browser) ──────────────
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# ── Auth (Better Auth) ─────────────────────────
# Min 32 chars: openssl rand -base64 32
BETTER_AUTH_SECRET=change_me_to_at_least_32_characters_random
# Public URL of this Next app (e.g. http://localhost:3000)
BETTER_AUTH_URL=http://localhost:3000
# Optional: same as BETTER_AUTH_SECRET if you prefer one var
AUTH_SECRET=
AUTH_TRUST_HOST=true

# ── Timezone ──────────────────────────────────
TZ=Asia/Jakarta
