# Backend
PORT=8080
HOST=0.0.0.0
DB=postgres://user:password@db:5432/dbname

# Security
JWT_SECRET=your-secure-jwt-secret-change-me
INIT_USER=admin
INIT_PASS=your-secure-password-change-me

# Logging
LOG_LEVEL=info
LOG_FILE_ENABLED=true

# Web
WEB_PORT=3000
BACKEND_URL=http://api:8080/v1
KONTAK_API_URL=http://api:8080/v1
AUTH_SECRET=your-secure-auth-secret-change-me
AUTH_TRUST_HOST=true
NEXT_PUBLIC_API_URL=http://localhost:3000
# For production, use your domain: NEXT_PUBLIC_API_URL=https://kontak.yourdomain.com

# Database
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=dbname

# External Database (set to true to use external DB instead of built-in)
USE_EXTERNAL_DB=false
# External DB connection (used when USE_EXTERNAL_DB=true)
# Example: EXTERNAL_DB=postgres://user:password@host:5432/dbname
EXTERNAL_DB=